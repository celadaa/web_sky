# ── Binarios y artefactos de compilación Go ──────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*-go-tmp-umask
# Ojo: usamos `/` al principio para que sólo coincida con el binario compilado
# en la raíz, no con la CARPETA `cmd/servidor/` (que contiene el código fuente).
/servidor
/skihub
/skihub.new
/bin/
/build/

# ── Tests ────────────────────────────────────────────────────────────────────
*.test
*.out
coverage.*

# ── Configuración local (NUNCA subir credenciales) ───────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Datos persistentes locales (BD legacy SQLite, dumps, etc.) ───────────────
/data/
/pgdata/
postgres-data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sql.dump
*.bak

# ── Editor / IDE ─────────────────────────────────────────────────────────────
/.idea/
/.vscode/*
!/.vscode/launch.json
*.swp
*.swo

# ── Sistema operativo ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# Carpeta de secretos LOCAL — nunca subir a GitHub
secretos-snowbreak/

