{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">¡Cuenta creada! 🎉</h1>
  <p class="hero__subtitle">Bienvenido/a a SkiHub, <strong>{{.Nombre}}</strong>. Tu registro se ha completado correctamente.</p>
</section>

<section class="container">
  <div style="max-width:520px;margin:0 auto;text-align:center;background:#fff;padding:2rem;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.06)">
    <p>Hemos guardado tu cuenta asociada al correo <strong>{{.Email}}</strong>.</p>
    <p style="margin-top:1rem;color:#64748B">Ahora inicia sesión para empezar a guardar tus pistas favoritas.</p>
    <p style="margin-top:1.5rem">
      <a href="/login" class="navbar__btn" style="text-decoration:none;display:inline-flex;align-items:center;gap:.4rem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
        Iniciar sesión
      </a>
    </p>
  </div>
</section>
{{end}}
