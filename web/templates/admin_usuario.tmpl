{{define "contenido"}}
{{with .Detalle}}
<section class="hero hero--home">
  <h1 class="hero__title">{{.Nombre}}</h1>
  <p class="hero__subtitle">
    {{.Email}}
    {{if .EsAdmin}} · <span class="admin-pill admin-pill--info">Admin</span>{{end}}
  </p>
</section>

<section class="container section-stack">
  <p><a href="/admin/usuarios" class="text-link">← Volver al listado</a></p>

  <div class="panel">
    <h2>Datos de la cuenta</h2>
    <dl class="admin-detail-grid">
      <dt>ID</dt><dd>{{.ID}}</dd>
      <dt>Nombre</dt><dd>{{.Nombre}}</dd>
      <dt>Correo</dt><dd>{{.Email}}</dd>
      <dt>Alta</dt><dd>{{.FechaRegistro.Format "02/01/2006 15:04"}}</dd>
      <dt>Rol</dt><dd>{{if .EsAdmin}}Administrador{{else}}Usuario{{end}}</dd>
    </dl>

    <div class="button-row section-stack">
      <form method="POST" action="/admin/usuarios/reset" class="inline-form">
        <input type="hidden" name="usuario_id" value="{{.ID}}">
        <button type="submit" class="admin-action admin-action--warn" onclick="return confirm('¿Resetear contraseña?')">Resetear contraseña</button>
      </form>
      <form method="POST" action="/admin/usuarios/toggle-admin" class="inline-form">
        <input type="hidden" name="usuario_id" value="{{.ID}}">
        <button type="submit" class="admin-action admin-action--role" onclick="return confirm('¿Cambiar rol?')">{{if .EsAdmin}}Quitar admin{{else}}Hacer admin{{end}}</button>
      </form>
      {{if not $.EsActual}}
      <form method="POST" action="/admin/usuarios/borrar" class="inline-form">
        <input type="hidden" name="usuario_id" value="{{.ID}}">
        <button type="submit" class="admin-action admin-action--danger" onclick="return confirm('¿Seguro que quieres borrar a {{.Email}}?')">Borrar cuenta</button>
      </form>
      {{end}}
    </div>
  </div>

  <div class="panel">
    <h2>Estaciones favoritas ({{len $.Favoritas}})</h2>
    {{if $.Favoritas}}
      <ul class="admin-favorites">
        {{range $.Favoritas}}
          <li class="admin-favorite-card">
            <img src="{{.Imagen}}" alt="{{.Nombre}}" loading="lazy">
            <div class="admin-favorite-card__body">
              <strong>{{.Nombre}}</strong>
              <p class="admin-muted">{{.Ubicacion}}</p>
              <p><a href="/estacion/{{.ID}}" class="text-link">Ver ficha</a></p>
            </div>
          </li>
        {{end}}
      </ul>
    {{else}}
      <p class="admin-muted">Este usuario todavía no ha marcado ninguna estación como favorita.</p>
    {{end}}
  </div>
</section>
{{end}}
{{end}}
