{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Cambiar contraseña</h1>
  <p class="hero__subtitle">Actualiza la contraseña de tu cuenta de SnowBreak.</p>
</section>

<section class="container section-stack">
  <div class="panel panel--form">
    {{if .Mensaje}}
      <div class="alert alert--success" role="status">
        {{.Mensaje}}
      </div>
    {{end}}
    {{if .Error}}
      <div class="alert alert--error" role="alert">
        {{.Error}}
      </div>
    {{end}}

    <form method="POST" action="/cambiar-password" class="form-stack">
      <div class="form-field">
        <label for="password_actual" class="form-label">Contraseña actual</label>
        <input id="password_actual" name="password_actual" type="password" required minlength="8" maxlength="128" autocomplete="current-password" class="form-input">
      </div>

      <div class="form-field">
        <label for="password_nueva" class="form-label">Contraseña nueva</label>
        <input id="password_nueva" name="password_nueva" type="password" required minlength="8" maxlength="128" autocomplete="new-password" class="form-input">
        <small class="form-help">Mínimo 8 caracteres. Debe ser distinta a la actual.</small>
      </div>

      <div class="form-field">
        <label for="password_nueva2" class="form-label">Repite la contraseña nueva</label>
        <input id="password_nueva2" name="password_nueva2" type="password" required minlength="8" maxlength="128" autocomplete="new-password" class="form-input">
      </div>

      <button type="submit" class="navbar__btn form-submit">Guardar cambios</button>
    </form>

    <p class="form-footnote">
      <a href="/" class="text-link">← Volver al inicio</a>
    </p>
  </div>
</section>
{{end}}
