{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Cambiar contraseña</h1>
  <p class="hero__subtitle">Actualiza la contraseña de tu cuenta de SkiHub.</p>
</section>

<section class="container">
  <div style="max-width:520px;margin:0 auto;background:#fff;padding:2rem;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.06)">
    {{if .Mensaje}}
      <div style="background:#DCFCE7;color:#166534;padding:.75rem 1rem;border-radius:8px;margin-bottom:1rem">
        ✓ {{.Mensaje}}
      </div>
    {{end}}
    {{if .Error}}
      <div style="background:#FEE2E2;color:#991B1B;padding:.75rem 1rem;border-radius:8px;margin-bottom:1rem">
        ✗ {{.Error}}
      </div>
    {{end}}

    <form method="POST" action="/cambiar-password" novalidate>
      <div style="margin-bottom:1rem">
        <label for="password_actual" style="display:block;font-weight:600;margin-bottom:.35rem">Contraseña actual</label>
        <input id="password_actual" name="password_actual" type="password" required minlength="8" maxlength="128"
               autocomplete="current-password"
               style="width:100%;padding:.6rem .8rem;border:1px solid #CBD5E1;border-radius:8px;font-size:1rem">
      </div>

      <div style="margin-bottom:1rem">
        <label for="password_nueva" style="display:block;font-weight:600;margin-bottom:.35rem">Contraseña nueva</label>
        <input id="password_nueva" name="password_nueva" type="password" required minlength="8" maxlength="128"
               autocomplete="new-password"
               style="width:100%;padding:.6rem .8rem;border:1px solid #CBD5E1;border-radius:8px;font-size:1rem">
        <small style="color:#64748B">Mínimo 8 caracteres. Debe ser distinta a la actual.</small>
      </div>

      <div style="margin-bottom:1.5rem">
        <label for="password_nueva2" style="display:block;font-weight:600;margin-bottom:.35rem">Repite la contraseña nueva</label>
        <input id="password_nueva2" name="password_nueva2" type="password" required minlength="8" maxlength="128"
               autocomplete="new-password"
               style="width:100%;padding:.6rem .8rem;border:1px solid #CBD5E1;border-radius:8px;font-size:1rem">
      </div>

      <button type="submit" class="navbar__btn" style="width:100%;justify-content:center">Guardar cambios</button>
    </form>

    <p style="text-align:center;margin-top:1.25rem;color:#64748B">
      <a href="/" style="color:#2563EB;text-decoration:none">← Volver al inicio</a>
    </p>
  </div>
</section>
{{end}}
