{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Panel de administración</h1>
  <p class="hero__subtitle">Bienvenido, <strong>{{.Usuario.Nombre}}</strong>. Hay <strong>{{.Total}}</strong> {{if eq .Total 1}}cuenta registrada{{else}}cuentas registradas{{end}}.</p>
</section>

<section class="container section-stack">
  {{if .Mensaje}}
    <div class="alert alert--success" role="status">{{.Mensaje}}</div>
  {{end}}
  {{if .Error}}
    <div class="alert alert--error" role="alert">{{.Error}}</div>
  {{end}}
  {{if .NuevaPwd}}
    <div class="alert alert--warning" role="status">
      Se ha generado una nueva contraseña para <strong>{{.PwdUsuario}}</strong>:
      <code>{{.NuevaPwd}}</code>
      <br>
      <small>Apúntala ahora; no volverá a mostrarse. El usuario deberá cambiarla después.</small>
    </div>
  {{end}}

  <div class="panel admin-table-wrap">
    {{if .Usuarios}}
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Alta</th>
          <th>Favs.</th>
          <th>Rol</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {{range .Usuarios}}
        <tr>
          <td class="admin-muted">{{.ID}}</td>
          <td>
            <a href="/admin/usuario/{{.ID}}" class="text-link">{{.Nombre}}</a>
            {{if .EsActual}}<small class="admin-muted">(tú)</small>{{end}}
          </td>
          <td>{{.Email}}</td>
          <td class="admin-muted">{{.FechaRegistro}}</td>
          <td>{{.NumFavoritos}}</td>
          <td>
            {{if .EsAdmin}}
              <span class="admin-pill admin-pill--info">Admin</span>
            {{else}}
              <span class="admin-pill admin-pill--muted">Usuario</span>
            {{end}}
          </td>
          <td class="admin-table__actions">
            <a href="/admin/usuario/{{.ID}}" class="admin-action admin-action--view">Ver</a>

            <form method="POST" action="/admin/usuarios/reset" class="inline-form">
              <input type="hidden" name="usuario_id" value="{{.ID}}">
              <button type="submit" class="admin-action admin-action--warn" onclick="return confirm('¿Resetear contraseña de {{.Email}}?\n\nSe generará una nueva contraseña aleatoria.')">Reset</button>
            </form>

            <form method="POST" action="/admin/usuarios/toggle-admin" class="inline-form">
              <input type="hidden" name="usuario_id" value="{{.ID}}">
              <button type="submit" class="admin-action admin-action--role" onclick="return confirm('¿Cambiar el rol de este usuario?')">{{if .EsAdmin}}Quitar admin{{else}}Hacer admin{{end}}</button>
            </form>

            {{if not .EsActual}}
            <form method="POST" action="/admin/usuarios/borrar" class="inline-form">
              <input type="hidden" name="usuario_id" value="{{.ID}}">
              <button type="submit" class="admin-action admin-action--danger" onclick="return confirm('¿Seguro que quieres borrar a {{.Email}}?\n\nSe perderán también sus favoritas y sesiones. Esta acción es irreversible.')">Borrar</button>
            </form>
            {{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
    {{else}}
    <p class="admin-muted">No hay usuarios registrados todavía.</p>
    {{end}}
  </div>

  <aside class="panel admin-help">
    <h2>Ayuda rápida</h2>
    <ul>
      <li><strong>Ver</strong> abre la ficha del usuario con sus estaciones favoritas.</li>
      <li><strong>Reset</strong> genera una contraseña aleatoria nueva y la muestra una sola vez.</li>
      <li><strong>Hacer / Quitar admin</strong> cambia el rol.</li>
      <li><strong>Borrar</strong> elimina la cuenta y todo lo asociado.</li>
    </ul>
  </aside>

  <section class="section-stack">
    <h2>API REST (PEC 3)</h2>
    <p class="admin-muted">
      Esta tabla se carga dinámicamente vía <code>fetch</code> contra
      <code>/api/usuarios</code>. Las acciones de <em>Editar</em> y
      <em>Eliminar</em> usan los métodos PUT y DELETE de la API.
    </p>

    <div class="panel admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="lista-usuarios"></tbody>
      </table>

      <template id="template-usuario">
        <tr>
          <td data-campo="nombre"></td>
          <td data-campo="email"></td>
          <td data-campo="rol"></td>
          <td class="admin-table__actions">
            <button type="button" data-accion="editar" class="admin-template-btn admin-template-btn--edit">Editar</button>
            <button type="button" data-accion="eliminar" class="admin-template-btn admin-template-btn--delete">Eliminar</button>
          </td>
        </tr>
      </template>
    </div>
  </section>

  <div id="notificacion" class="notificacion" aria-live="polite"></div>

  <div id="form-edicion" class="panel panel--form form-oculto">
    <h3>Editar usuario</h3>
    <div class="form-stack">
      <label class="form-field">
        <span class="form-label">Nombre</span>
        <input id="edit-nombre" type="text" required class="form-input">
      </label>
      <label class="form-field">
        <span class="form-label">Email</span>
        <input id="edit-email" type="email" required class="form-input">
      </label>
      <div class="button-row">
        <button id="edit-guardar" type="button" class="navbar__btn">Guardar</button>
        <button id="edit-cancelar" type="button" class="navbar__btn navbar__btn--ghost">Cancelar</button>
      </div>
    </div>
  </div>
</section>

<script src="/static/admin-api.js"></script>
{{end}}
