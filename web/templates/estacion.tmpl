{{define "contenido"}}
{{with .Estacion}}
<section class="hero hero--station">
  <a href="/estaciones" class="hero__btn-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
    Volver
  </a>
  <span class="hero__bg-fallback" aria-hidden="true"></span>
  {{if .Imagen}}<img src="{{.Imagen}}" alt="Estación de esquí {{.Nombre}}" fetchpriority="high" class="hero__bg-img" onerror="this.remove();">{{end}}

  <div class="hero__content">
    <div>
      <h1 class="hero__title">{{.Nombre}}</h1>
      <div class="hero__info-group">
        <p class="hero__info-text">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {{.Ubicacion}}
        </p>
        <p class="hero__info-text hero__info-text--success">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
          A {{printf "%.0f" .Distancia}} km de tu ubicación
        </p>
        <span class="status-badge status-badge--{{.EstadoClase}} status-badge--lg">{{.EstadoTexto}}</span>
      </div>
    </div>
    {{if $.Usuario}}
      <form method="POST" action="/favorito/toggle" class="inline-form">
        <input type="hidden" name="estacion_id" value="{{.ID}}">
        <input type="hidden" name="redirigir" value="/estacion/{{.ID}}">
        {{if .EsFavorita}}
          <button type="submit" class="hero__btn-action hero__btn-action--danger">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#991B1B" stroke="#991B1B" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            En favoritas
          </button>
        {{else}}
          <button type="submit" class="hero__btn-action">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Añadir a favoritas
          </button>
        {{end}}
      </form>
    {{else}}
      <a href="/login" class="hero__btn-action hero__btn-action--link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Inicia sesión para añadir a favoritas
      </a>
    {{end}}
  </div>
</section>

<div class="station-layout">
  <div class="station-layout__main">
    <article class="info-widget">
      <h2 class="info-widget__title">Sobre la estación</h2>
      <p>{{.Descripcion}}</p>
    </article>

    <section class="parte" data-parte data-estacion-id="{{.ID}}">
      <header class="parte__header">
        <div>
          <h2 class="parte__title">Parte de nieve</h2>
          <p class="parte__sub">Datos del estado de pistas, remontes y condiciones meteorológicas.</p>
        </div>
        <div class="parte__update">
          <span class="parte__update-tag" data-parte-tag>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Parte actualizado a las {{.ParteHora}}
          </span>
          <span class="parte__update-fecha" data-parte-fecha>Última actualización: {{.ParteActualizadoTexto}}</span>
          <button type="button" class="parte__refresh" data-parte-refresh aria-label="Actualizar parte">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
            Actualizar parte
          </button>
        </div>
      </header>

      <div class="parte__estado">
        <div class="parte__estado-card parte__estado-card--{{.EstadoClase}}">
          <span class="parte__estado-label">Estado general</span>
          <span class="parte__estado-valor" data-parte-estado>{{.EstadoTexto}}</span>
        </div>
        <div class="parte__estado-mini">
          <span class="parte__estado-mini-label">Pistas</span>
          <span class="parte__estado-mini-valor" data-parte-pistas>{{.PistasAbiertas}}/{{.PistasTotales}}</span>
          <span class="parte__estado-mini-label">Remontes</span>
          <span class="parte__estado-mini-valor" data-parte-remontes>{{.RemontesOp}}/{{.RemontesTot}}</span>
        </div>
      </div>

      <dl class="conditions__grid">
        <div class="conditions__item">
          <dt class="conditions__label">Temperatura</dt>
          <dd class="conditions__value" data-parte-temp>{{.Temperatura}} °C</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Nieve</dt>
          <dd class="conditions__value" data-parte-nieve>{{.NieveMin}}–{{.NieveMax}} cm</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Nieve nueva (24 h)</dt>
          <dd class="conditions__value text-success" data-parte-nueva>+ {{.NieveNueva}} cm</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Viento</dt>
          <dd class="conditions__value" data-parte-viento>{{.Viento}}</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Última nevada</dt>
          <dd class="conditions__value" data-parte-ultima>{{.UltimaNevada}}</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Pistas abiertas</dt>
          <dd class="conditions__value">{{.PistasAbiertas}} / {{.PistasTotales}}</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Remontes operativos</dt>
          <dd class="conditions__value">{{.RemontesOp}} / {{.RemontesTot}}</dd>
        </div>
        <div class="conditions__item">
          <dt class="conditions__label">Km esquiables</dt>
          <dd class="conditions__value">{{printf "%.0f" .KmEsquiables}} km</dd>
        </div>
      </dl>

      <div class="parte__loading" data-parte-loading hidden>
        <span class="snow-spinner" aria-hidden="true"></span>
        <span>Actualizando parte de nieve…</span>
      </div>
      <div class="parte__error" data-parte-error hidden role="alert">
        <strong>No hemos podido cargar los datos en este momento.</strong>
        <span>Inténtalo de nuevo en unos segundos.</span>
      </div>

      <p class="parte__disclaimer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><circle cx="12" cy="8" r="0.5" fill="currentColor"/></svg>
        Datos orientativos para demostración académica. Algunos valores pueden ser simulados con fines docentes.
      </p>
    </section>
  </div>

  <aside class="station-layout__aside">
    <section class="info-widget info-widget--highlight">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      <h2 class="visually-hidden">Distancia desde tu ubicación</h2>
      <p class="info-widget__value">{{printf "%.0f" .Distancia}} km</p>
      <p class="info-widget__note">Distancia en línea recta desde tu ubicación</p>
    </section>

    <section id="comprar"
             class="forfait-card"
             data-forfait-widget
             data-estacion-id="{{.ID}}"
             data-estacion-nombre="{{.Nombre}}"
             data-estacion-imagen="{{.Imagen}}"
             data-precio-adulto="{{printf "%.2f" .PrecioAdulto}}"
             data-precio-nino="{{printf "%.2f" .PrecioNino}}"
             data-precio-senior="{{printf "%.2f" .PrecioSenior}}">
      <header class="forfait-card__header">
        <h2 class="forfait-card__title">Compra tu Forfait</h2>
        <p class="forfait-card__price">
          <strong data-precio>{{printf "%.2f" .PrecioAdulto}} €</strong>
          <span>/ día</span>
        </p>
      </header>

      <div class="forfait-card__field">
        <label for="forfait-tipo" class="forfait-card__label">Tipo de pase</label>
        <select id="forfait-tipo" data-tipo-pase class="forfait-card__select">
          <option value="adulto">Adulto ({{printf "%.2f" .PrecioAdulto}} €)</option>
          <option value="nino">Niño ({{printf "%.2f" .PrecioNino}} €)</option>
          <option value="senior">Senior ({{printf "%.2f" .PrecioSenior}} €)</option>
        </select>
      </div>

      <div class="forfait-card__row">
        <div class="forfait-card__field">
          <label for="forfait-inicio" class="forfait-card__label">Fecha inicio</label>
          <input type="date" id="forfait-inicio" data-fecha-inicio class="forfait-card__input">
        </div>
        <div class="forfait-card__field">
          <label for="forfait-fin" class="forfait-card__label">Fecha fin</label>
          <input type="date" id="forfait-fin" data-fecha-fin class="forfait-card__input">
        </div>
      </div>

      <div class="forfait-card__field">
        <label for="forfait-cantidad" class="forfait-card__label">Cantidad</label>
        <input type="number" id="forfait-cantidad" data-cantidad min="1" value="1" class="forfait-card__input">
      </div>

      <div class="forfait-card__summary">
        <span>Duración: <strong data-dias>1 día</strong></span>
        <span>Total: <strong data-total>{{printf "%.2f" .PrecioAdulto}} €</strong></span>
      </div>

      <button type="button" class="forfait-card__cta" data-add-cart>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        Añadir a la cesta
      </button>
      <p class="forfait-card__feedback" data-feedback role="status" aria-live="polite"></p>
    </section>

    <section class="info-widget">
      <h2 class="info-widget__title">Información rápida</h2>
      <ul class="info-widget__list">
        <li class="info-widget__list-item">
          <span class="info-widget__label">Altitud</span>
          <span class="info-widget__data">{{.Altitud}}</span>
        </li>
        <li class="info-widget__list-item">
          <span class="info-widget__label">Km esquiables</span>
          <span class="info-widget__data">{{.KmEsquiables}} km</span>
        </li>
        <li class="info-widget__list-item">
          <span class="info-widget__label">Pistas totales</span>
          <span class="info-widget__data">{{.PistasTotales}}</span>
        </li>
        <li class="info-widget__list-item">
          <span class="info-widget__label">Nivel de dificultad</span>
          <span class="info-widget__data">{{.Dificultad}}</span>
        </li>
        <li class="info-widget__list-item">
          <span class="info-widget__label">Teléfono info.</span>
          <span class="info-widget__data">{{.Telefono}}</span>
        </li>
      </ul>
    </section>
  </aside>
</div>

<script src="/static/parte-refresh.js"></script>
{{end}}
{{end}}
