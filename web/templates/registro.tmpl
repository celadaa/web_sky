{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Crea tu cuenta en SkiHub</h1>
  <p class="hero__subtitle">Regístrate para guardar tus estaciones favoritas y recibir alertas de nevadas.</p>
</section>

<section class="container section-stack">
  <div class="panel panel--form">
    {{if .Error}}
      <div class="alert alert--error" role="alert">
        {{.Error}}
      </div>
    {{end}}

    <form method="POST" action="/registro" class="form-stack">
      <div class="form-field">
        <label for="nombre" class="form-label">Nombre</label>
        <input id="nombre" name="nombre" type="text" required minlength="2" maxlength="60" value="{{.Form.Nombre}}" class="form-input">
      </div>

      <div class="form-field">
        <label for="email" class="form-label">Correo electrónico</label>
        <input id="email" name="email" type="email" required maxlength="120" value="{{.Form.Email}}" class="form-input">
      </div>

      <div class="form-field">
        <label for="password" class="form-label">Contraseña</label>
        <input id="password" name="password" type="password" required minlength="8" maxlength="128" class="form-input">
        <small class="form-help">Mínimo 8 caracteres.</small>
      </div>

      <div class="form-field">
        <label for="password2" class="form-label">Repite la contraseña</label>
        <input id="password2" name="password2" type="password" required minlength="8" maxlength="128" class="form-input">
      </div>

      <button type="submit" class="navbar__btn form-submit">Crear cuenta</button>
    </form>
  </div>
</section>
{{end}}
