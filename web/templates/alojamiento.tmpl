{{define "contenido"}}
{{with .Alojamiento}}
<section class="hero hero--lodging">
  <a href="/estacion/{{.EstacionID}}" class="hero__btn-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
    Volver a {{.NombreEstacion}}
  </a>
  <span class="hero__bg-fallback" aria-hidden="true"></span>
  {{if .Imagen}}<img src="{{.Imagen}}" alt="{{.Nombre}}" fetchpriority="high" class="hero__bg-img" data-remove-on-error>{{end}}

  <div class="hero__content">
    <div>
      <span class="lodging-card__badge lodging-card__badge--hero">{{.TipoTexto}}</span>
      <h1 class="hero__title">{{.Nombre}}</h1>
      <div class="hero__info-group">
        <p class="hero__info-text">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {{.Zona}} · a {{printf "%.1f" .Distancia}} km de la estación
        </p>
        {{if gt .Valoracion 0.0}}
        <p class="hero__info-text">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15 8.5 22 9.3 17 14 18.3 21 12 17.8 5.7 21 7 14 2 9.3 9 8.5"/></svg>
          {{printf "%.1f" .Valoracion}} / 5
        </p>
        {{end}}
      </div>
    </div>
  </div>
</section>

<div class="lodging-detail">
  <div class="lodging-detail__container">
    <div class="lodging-detail__main">
      <h2 class="lodging-detail__heading">Sobre este alojamiento</h2>
      <p class="lodging-detail__desc">{{.Descripcion}}</p>
      <ul class="lodging-detail__features">
        <li><strong>Tipo:</strong> {{.TipoTexto}}</li>
        <li><strong>Zona:</strong> {{.Zona}}</li>
        <li><strong>Distancia a pistas:</strong> {{printf "%.1f" .Distancia}} km</li>
        <li><strong>Precio orientativo:</strong> desde {{printf "%.0f" .PrecioNoche}} € / noche</li>
      </ul>
    </div>

    <aside class="lodging-detail__aside" aria-label="Reserva de noches">
      <div class="lodging-booking" data-alojamiento-id="{{.ID}}" data-precio-noche="{{printf "%.2f" .PrecioNoche}}">
        <h3 class="lodging-booking__title">Reservar noches</h3>

        {{if $.YaLogueado}}
        <form id="lodging-booking-form" novalidate>
          <div class="lodging-booking__field">
            <label for="lodging-checkin">Fecha de entrada</label>
            <input type="date" id="lodging-checkin" name="fecha_entrada" required>
          </div>
          <div class="lodging-booking__field">
            <label for="lodging-checkout">Fecha de salida</label>
            <input type="date" id="lodging-checkout" name="fecha_salida" required>
          </div>
          <div class="lodging-booking__field">
            <label for="lodging-guests">Huéspedes</label>
            <input type="number" id="lodging-guests" name="huespedes" min="1" max="10" value="2" required>
          </div>

          <div class="lodging-booking__summary">
            <div class="lodging-booking__row">
              <span>Precio por noche</span>
              <strong>{{printf "%.0f" .PrecioNoche}} €</strong>
            </div>
            <div class="lodging-booking__row">
              <span>Noches</span>
              <strong data-noches>—</strong>
            </div>
            <div class="lodging-booking__row lodging-booking__row--total">
              <span>Total estimado</span>
              <strong data-total>—</strong>
            </div>
          </div>

          <button type="submit" class="lodging-booking__cta">Confirmar reserva</button>
          <p class="lodging-booking__feedback" data-feedback role="status" aria-live="polite"></p>
        </form>
        {{else}}
        <p class="lodging-booking__locked">
          Necesitas iniciar sesión para reservar.
        </p>
        <a href="/login" class="lodging-booking__cta lodging-booking__cta--secondary">Iniciar sesión</a>
        <a href="/registro" class="lodging-booking__link">o crear cuenta</a>
        {{end}}

        <p class="lodging-booking__note">
          Los precios son orientativos. La reserva queda confirmada en SnowBreak pero no se realiza ningún cobro en este entorno.
        </p>
      </div>
    </aside>
  </div>
</div>

<script src="/static/alojamientos.js"></script>
{{end}}
{{end}}
