{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Inicia sesión en Snowbreak</h1>
  <p class="hero__subtitle">Accede a tu cuenta para guardar estaciones favoritas y tenerlas siempre a mano.</p>
</section>

<section class="container section-stack">
  <div class="panel panel--form">
    {{if .Mensaje}}
      <div class="alert alert--success" role="status">
        {{.Mensaje}}
      </div>
    {{end}}
    {{if .Error}}
      <div class="alert alert--error" role="alert">
        {{.Error}}
      </div>
    {{end}}

    <form method="POST" action="/login" class="form-stack">
      <div class="form-field">
        <label for="email" class="form-label">Correo electrónico</label>
        <input id="email" name="email" type="email" required maxlength="120" value="{{.Email}}" autocomplete="email" class="form-input">
      </div>

      <div class="form-field">
        <label for="password" class="form-label">Contraseña</label>
        <input id="password" name="password" type="password" required minlength="8" maxlength="128" autocomplete="current-password" class="form-input">
      </div>

      <button type="submit" class="navbar__btn form-submit">Entrar</button>
    </form>

    <p class="form-footnote">
      ¿Todavía no tienes cuenta?
      <a href="/registro" class="text-link">Regístrate</a>
    </p>
  </div>
</section>
{{end}}
