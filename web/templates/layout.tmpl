{{define "layout"}}<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{.Descripcion}}">
  <title>{{.Titulo}}</title>
  <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
  <link rel="stylesheet" href="/static/css/main.css" fetchpriority="high">
</head>
<body>
  <a href="#contenido-principal" class="skip-link">Saltar al contenido</a>
  {{template "navbar" .}}
  <main id="contenido-principal">
    {{template "contenido" .}}
  </main>
  {{template "footer" .}}
  <script src="/static/nav.js"></script>
  <script src="/static/cart.js"></script>
</body>
</html>
{{end}}

{{define "navbar"}}
<header class="navbar">
  <div class="navbar__container">
    <a href="/" class="navbar__brand">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
      SkiHub
    </a>

    <button
      type="button"
      class="navbar__toggle"
      aria-expanded="false"
      aria-controls="navbar-nav"
      aria-label="Abrir menú de navegación">
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
    </button>

    <nav class="navbar__nav" id="navbar-nav">
      <ul class="navbar__list">
        <li><a href="/" class="navbar__link {{if eq .Activa "inicio"}}navbar__link--active{{end}}">Inicio</a></li>
        <li><a href="/estaciones" class="navbar__link {{if eq .Activa "estaciones"}}navbar__link--active{{end}}">Estaciones</a></li>
        <li><a href="/noticias" class="navbar__link {{if eq .Activa "noticias"}}navbar__link--active{{end}}">Noticias</a></li>
        <li><a href="/forfaits" class="navbar__link {{if eq .Activa "forfaits"}}navbar__link--active{{end}}">Comprar Forfaits</a></li>
        {{if .Usuario}}
          <li><a href="/favoritos" class="navbar__link {{if eq .Activa "favoritos"}}navbar__link--active{{end}}">Favoritas</a></li>
          {{if .Usuario.EsAdmin}}
            <li><a href="/admin/usuarios" class="navbar__link {{if eq .Activa "admin"}}navbar__link--active{{end}}">Admin</a></li>
          {{end}}
        {{end}}
      </ul>

      <div class="navbar__actions">
        {{if .Usuario}}
          <span class="navbar__welcome">Hola, <strong>{{.Usuario.Nombre}}</strong></span>
          <a href="/cambiar-password" class="navbar__link navbar__link--secondary {{if eq .Activa "cambiar_password"}}navbar__link--active{{end}}" title="Cambiar contraseña">Contraseña</a>
          {{template "cart_button" .}}
          <form method="POST" action="/logout" class="inline-form">
            <button type="submit" class="navbar__btn navbar__btn--ghost">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              Cerrar sesión
            </button>
          </form>
        {{else}}
          <a href="/login" class="navbar__link {{if eq .Activa "login"}}navbar__link--active{{end}}">Iniciar sesión</a>
          {{template "cart_button" .}}
          <a href="/registro" class="navbar__btn navbar__btn--link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Registrarse
          </a>
        {{end}}
      </div>
    </nav>
  </div>
</header>
{{end}}

{{define "cart_button"}}
<div class="cart-wrapper">
  <a href="/cesta" class="cart-button {{if eq .Activa "cesta"}}cart-button--active{{end}}" id="cart-button" aria-label="Cesta de la compra" aria-haspopup="true" aria-expanded="false">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="21" r="1"/>
      <circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    <span class="cart-button__badge" id="cart-count" hidden>0</span>
  </a>
  <div class="cart-dropdown" id="cart-dropdown" role="dialog" aria-label="Resumen de la cesta" hidden>
    <header class="cart-dropdown__header">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span>Cesta</span>
    </header>
    <ul class="cart-dropdown__items" id="cart-dropdown-items"></ul>
    <p class="cart-dropdown__empty" id="cart-dropdown-empty">Tu cesta está vacía.</p>
    <div class="cart-dropdown__footer" id="cart-dropdown-footer" hidden>
      <div class="cart-dropdown__subtotal">
        <span>Subtotal</span>
        <strong id="cart-dropdown-subtotal">0,00 €</strong>
      </div>
      <a href="/cesta" class="cart-dropdown__btn cart-dropdown__btn--ghost">Ver Cesta</a>
      <a href="/cesta" class="cart-dropdown__btn cart-dropdown__btn--primary">Proceder al Pago</a>
    </div>
  </div>
</div>
{{end}}

{{define "footer"}}
<footer class="footer">
  <div class="footer__grid">
    <div>
      <h2 class="footer__brand-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
        SkiHub
      </h2>
      <p>Tu portal de referencia para encontrar la mejor nieve, comprobar condiciones y planificar tu próximo viaje de esquí en la península.</p>
    </div>
    <nav aria-label="Navegación del pie de página">
      <h3 class="footer__title">Navegación</h3>
      <ul class="footer__list">
        <li><a href="/" class="footer__link">Inicio</a></li>
        <li><a href="/estaciones" class="footer__link">Estaciones</a></li>
        <li><a href="/noticias" class="footer__link">Noticias</a></li>
        {{if .Usuario}}
          <li><a href="/favoritos" class="footer__link">Mis favoritas</a></li>
        {{else}}
          <li><a href="/registro" class="footer__link">Registro</a></li>
          <li><a href="/login" class="footer__link">Iniciar sesión</a></li>
        {{end}}
      </ul>
    </nav>
    <div>
      <h3 class="footer__title">Información legal</h3>
      <ul class="footer__list">
        <li><a href="/legal/aviso-legal" class="footer__link">Aviso legal</a></li>
        <li><a href="/legal/privacidad" class="footer__link">Política de privacidad</a></li>
        <li><a href="/legal/cookies" class="footer__link">Política de cookies</a></li>
      </ul>
    </div>
  </div>
  <div class="footer__legal">
    <p>&copy; 2026 SkiHub. Datos proporcionados con fines académicos.</p>
  </div>
</footer>
{{end}}
