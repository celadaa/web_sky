{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Encuentra tu estación de esquí perfecta</h1>
  <p class="hero__subtitle">Descubre las mejores condiciones, distancias desde tu ubicación y el estado en tiempo real de las pistas.</p>
  <ul class="hero__pills">
    <li class="hero__pill">Ubicación de referencia: Madrid, España</li>
    {{with .MasCercana}}<li class="hero__pill">Más cercana: {{.Nombre}} a {{printf "%.1f" .Distancia}} km</li>{{end}}
  </ul>
</section>

<section>
  <ul class="stats-grid">
    <li>
      <article class="stats__item stats__item--near">
        <h3 class="stats__title">Más cercana</h3>
        <p class="stats__value">{{with .MasCercana}}<a href="/estaciones">{{.Nombre}}</a>{{end}}</p>
      </article>
    </li>
    <li>
      <article class="stats__item stats__item--avg">
        <h3 class="stats__title">Distancia promedio</h3>
        <p class="stats__value">{{printf "%.0f" .DistanciaPromedio}} km</p>
      </article>
    </li>
    <li>
      <article class="stats__item stats__item--far">
        <h3 class="stats__title">Más lejana</h3>
        <p class="stats__value">{{with .MasLejana}}<a href="/estaciones">{{.Nombre}}</a>{{end}}</p>
      </article>
    </li>
  </ul>
</section>

<section class="container">
  <div class="filters__header">
    <div>
      <h2>Estaciones cercanas</h2>
      <p>Basado en tu ubicación actual</p>
    </div>
    <div class="filters__controls">
      <button type="button" class="filters__view-btn filters__view-btn--active" data-vista="lista" aria-pressed="true">Lista</button>
      <button type="button" class="filters__view-btn" data-vista="mapa" aria-pressed="false">Mapa</button>
    </div>
  </div>

  <nav class="filters" aria-label="Filtros de estaciones">
    <ul class="filters__list" id="filtros-estaciones">
      <li><button type="button" class="filters__btn filters__btn--active" data-orden="cercanas" aria-pressed="true">Más cercanas</button></li>
      <li><button type="button" class="filters__btn" data-orden="nieve" aria-pressed="false">Más nieve</button></li>
      <li><button type="button" class="filters__btn" data-orden="pistas" aria-pressed="false">Más pistas</button></li>
      <li><button type="button" class="filters__btn" data-orden="recien" aria-pressed="false">Recién nevado</button></li>
    </ul>
  </nav>

  <ul class="grid-cards" id="grid-estaciones">
    {{range .Estaciones}}
    <li data-distancia="{{.Distancia}}" data-nieve="{{.NieveBase}}" data-pistas="{{.PistasAbiertas}}" data-nieve-nueva="{{.NieveNueva}}">
      <article class="station-card">
        <figure class="station-card__figure">
          <span class="station-card__badge">{{printf "%.1f" .Distancia}} km</span>
          {{if $.Usuario}}
          <form method="POST" action="/favorito/toggle" class="station-card__favorite-form">
            <input type="hidden" name="estacion_id" value="{{.ID}}">
            <input type="hidden" name="redirigir" value="/">
            <button type="submit" class="station-card__favorite" aria-label="{{if .EsFavorita}}Quitar {{.Nombre}} de favoritas{{else}}Añadir {{.Nombre}} a favoritas{{end}}">
              {{if .EsFavorita}}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#DC2626" stroke="#DC2626" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {{else}}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {{end}}
            </button>
          </form>
          {{end}}
          <a href="/estacion/{{.ID}}" tabindex="-1" aria-hidden="true">
            <img src="{{.Imagen}}" alt="Vista de {{.Nombre}}" loading="lazy" class="station-card__image">
          </a>
        </figure>
        <a href="/estacion/{{.ID}}" class="station-card__content">
          <h3 class="station-card__name">{{.Nombre}}</h3>
          <p class="station-card__location">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{.Ubicacion}}
          </p>
          <dl class="station-card__data">
            <div class="station-card__data-item">
              <dt class="visually-hidden">Temperatura</dt>
              <dd>{{.Temperatura}} °C</dd>
            </div>
            <div class="station-card__data-item">
              <dt class="visually-hidden">Nieve base</dt>
              <dd>{{.NieveBase}} cm</dd>
            </div>
          </dl>
        </a>
      </article>
    </li>
    {{end}}
  </ul>

  <div id="mapa-container" class="map-card oculto" aria-live="polite">
    <div id="mapa-leaflet" class="map-card__canvas"></div>
  </div>
</section>

<script src="/static/filtros.js"></script>
<script src="/static/mapa.js"></script>
{{end}}
