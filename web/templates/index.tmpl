{{define "contenido"}}
<section class="hero hero--premium-v2">
  <div class="hero__premium-v2-inner">
    <span class="hero__eyebrow-pill">Estaciones de esquí · Nieve · Forfaits</span>
    <h1 class="hero__title-v2">PLANIFICA TU DÍA PERFECTO EN LA NIEVE</h1>
    <p class="hero__subtitle-v2">
      Consulta estaciones, estado de pistas, nieve disponible y reserva tus forfaits desde un solo lugar.
    </p>

    <div id="hero-estaciones-data" hidden aria-hidden="true">{{range .Estaciones}}<span data-id="{{.ID}}" data-nombre="{{.Nombre}}" data-ubicacion="{{.Ubicacion}}"></span>{{end}}</div>

    <form action="/estaciones" method="GET" class="hero__search-v2" role="search" aria-label="Buscar estaciones" id="hero-search-form" novalidate>
      <div class="hero__sv2-field hero__sv2-field--ac" id="hero-ac-wrap">
        <label class="hero__sv2-label" for="hero-destino">Destino o estación</label>
        <input id="hero-destino" type="text" name="q" class="hero__sv2-input" placeholder="Busca Baqueira, Sierra Nevada, Formigal…" autocomplete="off" aria-label="Destino o estación" aria-autocomplete="list" aria-controls="hero-ac-list" aria-haspopup="listbox" role="combobox" aria-expanded="false">
        <input type="hidden" id="hero-estacion-id" name="id_estacion" value="">
        <ul id="hero-ac-list" class="home-ac" role="listbox" aria-label="Estaciones sugeridas" hidden></ul>
      </div>
      <div class="hero__sv2-sep"></div>
      <div class="hero__sv2-field hero__sv2-field--dp" id="hero-dp-wrap">
        <label class="hero__sv2-label" for="hero-fechas-display">Fechas</label>
        <input id="hero-fechas-display" type="text" class="hero__sv2-input hero__sv2-input--dates" placeholder="Selecciona fechas" readonly aria-label="Rango de fechas" aria-haspopup="dialog" aria-expanded="false">
        <input type="hidden" id="hero-fecha-inicio" name="fecha_inicio" value="">
        <input type="hidden" id="hero-fecha-fin" name="fecha_fin" value="">
      </div>
      <div class="hero__sv2-sep"></div>
      <div class="hero__sv2-field">
        <label class="hero__sv2-label" for="hero-tipo">Tipo</label>
        <select id="hero-tipo" name="tipo" class="hero__sv2-input hero__sv2-select" aria-label="Tipo de actividad">
          <option value="">Todos los tipos</option>
          <option value="alpino">Esquí alpino</option>
          <option value="snowboard">Snowboard</option>
          <option value="familiar">Familiar</option>
          <option value="principiante">Principiante</option>
          <option value="forfait">Forfait diario</option>
        </select>
      </div>
      <button type="submit" class="hero__sv2-btn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Buscar estaciones
      </button>
    </form>

    <div class="hero__ubic" data-ubicacion-selector></div>

    <ul class="hero__metrics-v2" aria-label="Métricas destacadas">
      <li>
        <span class="hero__mv2-value">{{with .MasCercana}}{{.Nombre}}{{else}}—{{end}}</span>
        <span class="hero__mv2-label">Más cercana · {{with .MasCercana}}{{printf "%.0f" .Distancia}} km{{else}}sin datos{{end}}</span>
      </li>
      <li class="hero__mv2-sep" aria-hidden="true"></li>
      <li>
        <span class="hero__mv2-value">{{printf "%.0f" .DistanciaPromedio}} km</span>
        <span class="hero__mv2-label">Distancia media</span>
      </li>
      <li class="hero__mv2-sep" aria-hidden="true"></li>
      <li>
        <span class="hero__mv2-value">{{len .Estaciones}}</span>
        <span class="hero__mv2-label">Estaciones disponibles</span>
      </li>
    </ul>
  </div>
</section>

<section>
  <ul class="stats-grid">
    <li>
      <article class="stats__item stats__item--near">
        <h3 class="stats__title">Más cercana</h3>
        <p class="stats__value">{{with .MasCercana}}<a href="/estaciones">{{.Nombre}}</a>{{end}}</p>
      </article>
    </li>
    <li>
      <article class="stats__item stats__item--avg">
        <h3 class="stats__title">Distancia promedio</h3>
        <p class="stats__value">{{printf "%.0f" .DistanciaPromedio}} km</p>
      </article>
    </li>
    <li>
      <article class="stats__item stats__item--far">
        <h3 class="stats__title">Más lejana</h3>
        <p class="stats__value">{{with .MasLejana}}<a href="/estaciones">{{.Nombre}}</a>{{end}}</p>
      </article>
    </li>
  </ul>
</section>

<section class="container pistas-home" id="home-pistas-directo">
  <div class="pistas-home__header">
    <div>
      <h2>Estado de pistas en directo</h2>
      <p class="pistas-home__aviso" data-home-pistas-aviso>Consultando el estado actualizado de las pistas…</p>
    </div>
    <a href="/pistas" class="text-link">Ver todas las pistas →</a>
  </div>
  <ul class="pistas-home__list" data-home-pistas-lista>
    <li class="pistas-home__item"><div class="skeleton skeleton--pista" aria-hidden="true"></div></li>
    <li class="pistas-home__item"><div class="skeleton skeleton--pista" aria-hidden="true"></div></li>
    <li class="pistas-home__item"><div class="skeleton skeleton--pista" aria-hidden="true"></div></li>
  </ul>
</section>

<section class="container">
  <div class="filters__header">
    <div>
      <h2>Estaciones cercanas a ti</h2>
      <p>Ordena por distancia, espesor de nieve o pistas abiertas.</p>
    </div>
    <div class="filters__controls">
      <button type="button" class="filters__view-btn filters__view-btn--active" data-vista="lista" aria-pressed="true">Lista</button>
      <button type="button" class="filters__view-btn" data-vista="mapa" aria-pressed="false">Mapa</button>
    </div>
  </div>

  <div class="estaciones-toolbar estaciones-toolbar--home">
    <div class="estaciones-toolbar__contador" data-resultados-contador>{{len .Estaciones}} estaciones encontradas</div>
    <div class="estaciones-toolbar__orden">
      <label for="selector-orden">Ordenar por:</label>
      <select id="selector-orden" class="estaciones-toolbar__select">
        <option value="cercana">Más cercana</option>
        <option value="nieve">Más nieve</option>
        <option value="precio">Más barata</option>
        <option value="pistas">Más pistas abiertas</option>
        <option value="rating">Mejor valorada</option>
      </select>
      <a href="/estaciones" class="estaciones-toolbar__btn">Filtros avanzados →</a>
    </div>
  </div>

  <ul class="grid-cards" id="grid-estaciones" data-grid-estaciones>
    {{range .Estaciones}}
    <li
      data-estacion
      data-id="{{.ID}}"
      data-nombre="{{.Nombre}}"
      data-ubicacion="{{.Ubicacion}}"
      data-distancia="{{printf "%.1f" .Distancia}}"
      data-precio="{{printf "%.2f" .PrecioNino}}"
      data-nieve="{{.NieveBase}}"
      data-nieve-min="{{.NieveMin}}"
      data-nieve-max="{{.NieveMax}}"
      data-nieve-nueva="{{.NieveNueva}}"
      data-viento="{{.Viento}}"
      data-parte-hora="{{.ParteHora}}"
      data-parte-fecha="{{.ParteActualizadoTexto}}"
      data-km-esquiables="{{.KmEsquiables}}"
      data-pistas-abiertas="{{.PistasAbiertas}}"
      data-pistas-totales="{{.PistasTotales}}"
      data-dificultad="{{.Dificultad}}"
      data-rating="{{if gt .NieveBase 0}}{{printf "%.1f" (.KmEsquiables)}}{{else}}0{{end}}"
      data-favorita="{{if .EsFavorita}}1{{else}}0{{end}}"
      data-url="/estacion/{{.ID}}">
      <article class="station-card">
        <figure class="station-card__figure">
          <span class="station-card__badge" data-distancia-badge>{{printf "%.0f" .Distancia}} km</span>
          <button type="button"
            class="station-card__compare"
            data-toggle-comparar
            aria-pressed="false"
            aria-label="Añadir {{.Nombre}} al comparador">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h13"/><path d="m16 3 3 3-3 3"/><path d="M21 18H8"/><path d="m8 21-3-3 3-3"/></svg>
            <span data-comparar-label>Comparar</span>
          </button>
          {{if $.Usuario}}
          <form method="POST" action="/favorito/toggle" class="station-card__favorite-form">
            <input type="hidden" name="estacion_id" value="{{.ID}}">
            <input type="hidden" name="redirigir" value="/">
            <button type="submit"
              class="station-card__favorite {{if .EsFavorita}}is-active{{end}}"
              data-toggle-favorita
              data-logueado="1"
              aria-label="{{if .EsFavorita}}Quitar {{.Nombre}} de favoritas{{else}}Guardar {{.Nombre}} en favoritas{{end}}">
              {{if .EsFavorita}}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#DC2626" stroke="#DC2626" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {{else}}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {{end}}
            </button>
          </form>
          {{else}}
          <button type="button"
            class="station-card__favorite"
            data-toggle-favorita
            data-logueado="0"
            aria-label="Guardar {{.Nombre}} en favoritas">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
          {{end}}
          <a href="/estacion/{{.ID}}" tabindex="-1" aria-hidden="true" class="station-card__media">
            <span class="station-cover" data-station="{{.Nombre}}" aria-hidden="true">
              <svg class="station-cover__icon" width="56" height="56" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 50 L22 22 L32 38 L44 16 L58 50 Z"/>
                <path d="M22 22 L26 28"/>
                <path d="M44 16 L48 22"/>
              </svg>
              <span class="station-cover__label">{{.Nombre}}</span>
            </span>
            {{if .Imagen}}<img src="{{.Imagen}}" alt="Estación de esquí {{.Nombre}}" loading="lazy" class="station-card__image" data-broken-parent="station-card__media--broken" data-remove-on-error>{{end}}
          </a>
        </figure>
        <a href="/estacion/{{.ID}}" class="station-card__content">
          <div class="station-card__head">
            <h3 class="station-card__name">{{.Nombre}}</h3>
            <span class="status-badge status-badge--{{.EstadoClase}}">{{.EstadoTexto}}</span>
          </div>
          <p class="station-card__location">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{.Ubicacion}}
          </p>
          <dl class="station-metrics">
            <div class="station-metric">
              <span class="station-metric__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              </span>
              <div class="station-metric__body">
                <dt class="station-metric__label">Distancia</dt>
                <dd class="station-metric__value" data-distancia-metric>{{printf "%.0f" .Distancia}} km</dd>
              </div>
            </div>
            <div class="station-metric">
              <span class="station-metric__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l5-3 5 3v12"/><path d="M15 20V11l4-2 0 11"/></svg>
              </span>
              <div class="station-metric__body">
                <dt class="station-metric__label">Nieve</dt>
                <dd class="station-metric__value">{{.NieveBase}} cm</dd>
              </div>
            </div>
            <div class="station-metric">
              <span class="station-metric__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <div class="station-metric__body">
                <dt class="station-metric__label">Pistas</dt>
                <dd class="station-metric__value">{{.PistasAbiertas}}/{{.PistasTotales}}</dd>
              </div>
            </div>
            <div class="station-metric">
              <span class="station-metric__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </span>
              <div class="station-metric__body">
                <dt class="station-metric__label">Temperatura</dt>
                <dd class="station-metric__value">{{.Temperatura}} °C</dd>
              </div>
            </div>
          </dl>
          <p class="station-card__parte">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Parte actualizado a las {{.ParteHora}}
          </p>
        </a>
        <div class="station-card__footer-bar">
          <div class="station-card__price">
            <span class="station-card__price-label">Forfait desde</span>
            <span class="station-card__price-value">{{printf "%.0f" .PrecioNino}} €<small> /día</small></span>
          </div>
          <a href="/estacion/{{.ID}}" class="station-card__cta">
            Ver ficha
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    </li>
    {{end}}
  </ul>

  <div id="mapa-container" class="map-card oculto" aria-live="polite">
    <header class="map-card__header">
      <div>
        <h3 class="map-card__title">Mapa de estaciones</h3>
        <p class="map-card__subtitle">Pulsa un esquiador para ver el estado de la estación · 27 estaciones agrupadas por macizo</p>
      </div>
      <article id="ubicacion-card" class="ubicacion-card oculto" aria-live="polite">
        <span class="ubicacion-card__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <div class="ubicacion-card__body">
          <strong class="ubicacion-card__title" data-ub-titulo>Tu ubicación</strong>
          <span class="ubicacion-card__address" data-ub-direccion></span>
          <span class="ubicacion-card__coords" data-ub-coords></span>
        </div>
      </article>
    </header>
    <div class="map-card__layout">
      <aside class="map-sidebar" aria-label="Estaciones agrupadas por macizo">
        <div class="map-sidebar__search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input id="mapa-search" type="search" placeholder="Buscar estación…" aria-label="Buscar estación">
        </div>
        <ul class="map-sidebar__chips" id="mapa-filtros" aria-label="Filtros por macizo"></ul>
        <div class="map-sidebar__groups" id="mapa-grupos" aria-live="polite"></div>
      </aside>
      <div id="mapa-leaflet" class="map-card__canvas"></div>
    </div>
  </div>
</section>

<div id="comparador-bar" class="comparador-bar" hidden></div>

<script src="/static/mapa.js"></script>
<script src="/static/pistas-home.js"></script>
<script src="/static/home-search.js"></script>
{{end}}
