{{define "contenido"}}
<section class="hero hero--news">
  <h1 class="hero__title hero__title--icon">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
    Noticias de esquí
  </h1>
  <p class="hero__subtitle">Mantente informado sobre las últimas nevadas, próximos eventos y los mejores consejos para la temporada.</p>
</section>

<section class="container">
  <nav class="filters" aria-label="Filtros de noticias">
    <ul class="filters__list" id="filtros-noticias">
      <li><button type="button" class="filters__btn filters__btn--active" data-categoria="todas" aria-pressed="true">Todas</button></li>
      <li><button type="button" class="filters__btn" data-categoria="nevada" aria-pressed="false">Nevadas</button></li>
      <li><button type="button" class="filters__btn" data-categoria="evento" aria-pressed="false">Eventos</button></li>
      <li><button type="button" class="filters__btn" data-categoria="consejos" aria-pressed="false">Consejos</button></li>
      <li><button type="button" class="filters__btn" data-categoria="general" aria-pressed="false">General</button></li>
    </ul>
  </nav>

  <ul class="grid-cards" id="grid-noticias">
    {{range .Noticias}}
    <li data-categoria="{{.CategoriaClase}}">
      <article class="news-card news-card--static">
        <figure class="news-card__figure">
          <span class="news-card__tag news-card__tag--{{.CategoriaClase}}">{{.Categoria}}</span>
          <img src="{{.Imagen}}" alt="{{.Titulo}}" loading="lazy" class="news-card__image">
        </figure>
        <div class="news-card__content">
          <time class="news-card__date" datetime="{{.FechaISO}}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {{.FechaLarga}}
          </time>
          <h2 class="news-card__title">{{.Titulo}}</h2>
          <p class="news-card__excerpt">{{.Extracto}}</p>
          <p class="news-card__more">Resumen editorial disponible en esta página.</p>
        </div>
      </article>
    </li>
    {{end}}
  </ul>
</section>

<script src="/static/filtros.js"></script>
{{end}}
