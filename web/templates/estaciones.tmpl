{{define "contenido"}}
<section class="hero hero--home">
  <h1 class="hero__title">Estaciones de esquí</h1>
  <p class="hero__subtitle">
    {{if .Usuario}}
      Hola <strong>{{.Usuario.Nombre}}</strong>. Marca con ❤️ tus pistas favoritas para guardarlas en tu cuenta.
    {{else}}
      Consulta el listado completo y <a href="/login" style="color:#fff;text-decoration:underline">inicia sesión</a> para guardar tus favoritas.
    {{end}}
  </p>
</section>

<section class="container">
  <ul class="grid-cards">
    {{range .Estaciones}}
    <li>
      <article class="station-card">
        <figure class="station-card__figure">
          <span class="station-card__badge">{{printf "%.1f" .Distancia}} km</span>
          <a href="/estacion/{{.ID}}" tabindex="-1" aria-hidden="true">
            <img src="{{.Imagen}}" alt="Vista de {{.Nombre}}" loading="lazy" class="station-card__image">
          </a>
        </figure>
        <a href="/estacion/{{.ID}}" class="station-card__content">
          <h3 class="station-card__name">{{.Nombre}}</h3>
          <p class="station-card__location">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{.Ubicacion}}
          </p>
          <dl class="station-card__data">
            <div class="station-card__data-item">
              <dt class="visually-hidden">Temperatura</dt>
              <dd>🌡️ {{.Temperatura}}°C</dd>
            </div>
            <div class="station-card__data-item">
              <dt class="visually-hidden">Nieve base</dt>
              <dd>❄️ {{.NieveBase}} cm</dd>
            </div>
          </dl>
        </a>
        {{if $.Usuario}}
        <form method="POST" action="/favorito/toggle" style="padding:0 1rem 1rem">
          <input type="hidden" name="estacion_id" value="{{.ID}}">
          <input type="hidden" name="redirigir" value="/estaciones">
          {{if .EsFavorita}}
            <button type="submit" aria-label="Quitar {{.Nombre}} de favoritas" style="width:100%;background:#FEE2E2;color:#991B1B;border:1px solid #FCA5A5;border-radius:8px;padding:.5rem;cursor:pointer;font-weight:600">
              ❤️ En favoritas
            </button>
          {{else}}
            <button type="submit" aria-label="Añadir {{.Nombre}} a favoritas" style="width:100%;background:#F1F5F9;color:#1E293B;border:1px solid #CBD5E1;border-radius:8px;padding:.5rem;cursor:pointer;font-weight:600">
              🤍 Añadir a favoritas
            </button>
          {{end}}
        </form>
        {{else}}
        <p style="padding:0 1rem 1rem;color:#64748B;font-size:.85rem;text-align:center">
          <a href="/login" style="color:#2563EB;font-weight:600;text-decoration:none">Inicia sesión</a> para marcar favoritas
        </p>
        {{end}}
      </article>
    </li>
    {{end}}
  </ul>
</section>
{{end}}
