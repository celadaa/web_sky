{{define "contenido"}}
<section class="error-page">
  <div class="error-page__inner">
    <span class="error-page__icon" aria-hidden="true">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 19 9 9l4 6 3-4 5 8z"/>
        <path d="M2 21h20"/>
        <circle cx="17" cy="6" r="2"/>
      </svg>
    </span>
    <p class="error-page__code">{{.Codigo}}</p>
    {{if eq .Codigo 404}}
      <h1 class="error-page__title">No hemos encontrado esta pista</h1>
      <p class="error-page__description">La ruta que buscas no existe o se ha cubierto de nieve. Vuelve al inicio o explora las estaciones disponibles.</p>
    {{else}}
      <h1 class="error-page__title">{{.Mensaje}}</h1>
      <p class="error-page__description">{{.Detalle}}</p>
    {{end}}
    <div class="error-page__actions">
      <a href="/" class="cta-btn cta-btn--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2z"/></svg>
        Volver al inicio
      </a>
      <a href="/estaciones" class="cta-btn cta-btn--secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Ver estaciones
      </a>
    </div>
  </div>
</section>
{{end}}
