# ─── SkiHub (Snowbreak) — Variables de entorno ──────────────────────────────
# Copia este fichero a `.env` y rellena los valores reales.
# El fichero `.env` NUNCA se sube al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=skihub
DB_PASSWORD=cambia_esto_por_una_contrasena_segura
DB_NAME=skihub
# Modos válidos: disable | require | verify-ca | verify-full
# - disable: solo desarrollo local
# - require: producción mínima (cifrado, sin validar CA)
# - verify-full: producción recomendada
DB_SSLMODE=disable

# Tamaño del pool de conexiones (opcionales, valores por defecto sensatos)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=30

# ── Servidor HTTP ────────────────────────────────────────────────────────────
APP_PORT=:8080
APP_TEMPLATES=web/templates
APP_STATIC=web/static

# ── Administrador inicial ────────────────────────────────────────────────────
# Si al arrancar no existe ningún admin, se crea uno con estos datos.
# Cambia la contraseña tras el primer login.
ADMIN_EMAIL=admin@skihub.local
ADMIN_NAME=Administrador
ADMIN_PASSWORD=cambia_esto_admin1234
