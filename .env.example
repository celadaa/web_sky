# ─── SkiHub (Snowbreak) — Variables de entorno ──────────────────────────────
# Copia este fichero a `.env` y rellena los valores reales.
# El fichero `.env` NUNCA se sube al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ──────────────────────────────────────────────────────────────────
# development | production
# En production: COOKIE_SECURE=1, DB_SSLMODE distinto de "disable", CSRF_SECRET
# obligatorio (32+ chars), HSTS activo, etc.
APP_ENV=development

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=skihub
DB_PASSWORD=cambia_esto_por_una_contrasena_segura
DB_NAME=skihub
# Modos válidos: disable | require | verify-ca | verify-full
# - disable: solo desarrollo local
# - require: producción mínima (cifrado, sin validar CA)
# - verify-full: producción recomendada
DB_SSLMODE=disable

# Tamaño del pool de conexiones (opcionales, valores por defecto sensatos)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=30

# ── Servidor HTTP ────────────────────────────────────────────────────────────
APP_PORT=:8080
APP_TEMPLATES=web/templates
APP_STATIC=web/static

# ── Seguridad ────────────────────────────────────────────────────────────────
# CSRF_SECRET — semilla del HMAC para los tokens CSRF.
#   - 32+ caracteres aleatorios.
#   - Generar con: openssl rand -hex 32
#   - Si está vacía en development se genera una efímera al arrancar.
#   - OBLIGATORIA en production.
CSRF_SECRET=

# COOKIE_SECURE — emite cookies con flag Secure (solo HTTPS).
#   true en producción detrás de TLS; false en localhost sin TLS.
#   Si se omite, por defecto se activa cuando APP_ENV=production.
# COOKIE_SECURE=true

# TRUST_PROXY — confía en X-Forwarded-For/X-Real-IP (solo si la app está
# detrás de un reverse proxy de tu confianza, p.ej. Nginx/Cloudflare).
TRUST_PROXY=false

# Tamaño máximo (bytes) de cuerpo POST/PUT que aceptamos. Defensa básica
# contra body-flooding. Default 1 MiB.
BODY_MAX_BYTES=1048576

# Peticiones por minuto por IP en endpoints sensibles (login, registro,
# checkout, favoritos, parte refresh). Default 30.
RATE_LIMIT_PER_MIN=30

# ── Administrador inicial ────────────────────────────────────────────────────
# Si al arrancar no existe ningún admin, se crea uno con estos datos.
# Cambia la contraseña tras el primer login.
# En producción la contraseña debe tener al menos 12 caracteres.
ADMIN_EMAIL=admin@skihub.local
ADMIN_NAME=Administrador
ADMIN_PASSWORD=cambia_esto_admin1234
